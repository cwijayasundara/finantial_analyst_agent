# Local-only by default. Remote LLM is gated behind an explicit opt-in below.
OLLAMA_BASE_URL=http://127.0.0.1:11434
PFH_LLM_MODEL=ollama:qwen3.6:35b
PFH_EMBED_MODEL=ollama:nomic-embed-text
PFH_DATA_DIR=./data
PFH_SOURCES_DIR=./sources
PFH_PARSED_DIR=./parsed
PFH_WIKI_DIR=./wiki
PFH_GRAPH_DIR=./graph
PFH_OUT_DIR=./out

# --- Remote LLM opt-in (off by default) ---
# Set to `true` AND switch PFH_LLM_MODEL to an `openai:<model>` id to route
# the categoriser to the OpenAI API. Outbound merchant strings are run
# through cookbooks._shared.pii.mask_pii first (sort code, IBAN, postcode,
# phone, email, 8+ digit runs). No raw statement text ever leaves the box —
# only the masked merchant surface forms.
# PFH_ALLOW_REMOTE_LLM=true
# PFH_LLM_MODEL=openai:gpt-5.4-mini
# OPENAI_API_KEY=sk-...
# Comma-separated names/strings to mask as [NAME] in outbound payloads.
# Use this for your own and family surnames since the regex masker
# cannot detect names structurally. The post-mask guard will REFUSE to
# send any prompt that still contains a denylist hit.
# PFH_PII_DENYLIST=YOURSURNAME,FAMILYSURNAME
# Parallel LLM calls per file (default 8). Bound by remote rate limits;
# DB writes stay serial regardless of this setting.
# PFH_CATEGORISE_CONCURRENCY=8
